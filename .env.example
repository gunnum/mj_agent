MJ_AGENT_HOST=127.0.0.1
MJ_AGENT_PORT=18123
MJ_RUNTIME_DIR=/Users/your-user/Documents/ide/midjourney-agent/runtime
MJ_REQUEST_LOG_DIR=/Users/your-user/Documents/ide/midjourney-agent/runtime/request-logs
MJ_TOKEN_REGISTRY_PATH=/Users/your-user/Documents/ide/midjourney-agent/runtime/token-registry.md
# MJ_API_TOKEN=replace-with-a-long-random-token
# MJ_CORS_ORIGINS=https://app.example.com,https://admin.example.com
MJ_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
MJ_PROFILE_NAME=default
# MJ_USER_DATA_DIR=/Users/your-user/.midjourney-agent/default
MJ_HEADLESS=false
MJ_TIMEOUT_MS=30000
MJ_EXPLORE_URL=https://www.midjourney.com/explore
